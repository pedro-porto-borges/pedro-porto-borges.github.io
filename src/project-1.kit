<!DOCTYPE html>
<html lang="en">

<!--@import "_head.kit"-->

<body>
    <!--@import "_header.kit"-->

    <main class="mova-case project-case" id="movaCase">
        <div class="mova-shell" id="movaShell">
            <button class="mova-sidebar-toggle sidebar-toggle" id="movaSidebarToggle" type="button"
                aria-label="Open sidebar" aria-controls="movaSidebar" aria-expanded="false">
                <span class="mova-toggle-open" aria-hidden="true">&#9776;</span>
                <span class="mova-toggle-close" aria-hidden="true">&times;</span>
            </button>

            <aside class="mova-sidebar sidebar" id="movaSidebar" aria-label="Itaú + MOVA case study navigation">
                <div class="mova-sidebar-brand">
                    <p class="mova-section-label">Itaú + MOVA</p>
                    <strong>Case Study</strong>
                </div>
                <nav class="mova-sidebar-nav">
                    <a href="#overview">Overview</a>
                    <a href="#context">Context</a>
                    <a href="#mova">MOVA</a>
                    <a href="#challenge">Challenge</a>
                    <a href="#role">Role</a>
                    <a href="#research">Research</a>
                    <a href="#solution">Solution</a>
                    <a href="#results">Results</a>
                    <a href="#reflection">Reflection</a>
                </nav>
            </aside>

            <div class="mova-sidebar-overlay" id="movaSidebarOverlay" aria-hidden="true"></div>

            <article class="mova-case-study" id="mainContent">
                <section class="mova-hero" id="overview" aria-label="Project snapshot">
                    <div class="mova-hero-copy">
                        <a href="/portfolio.html" class="back-link">Back to portfolio</a>
                        <p class="mova-section-label">Itaú + MOVA</p>
                        <h1>Optimizing the in-store installment financing journey</h1>
                        <p>A redesign of MOVA's assisted sales flow to make installment financing faster for operators,
                            clearer for customers and safer for a sensitive financial decision.</p>
                        <ul class="mova-tag-list" aria-label="Project tags">
                            <li>Product Strategy</li>
                            <li>Journey Mapping</li>
                            <li>Assisted Sales</li>
                            <li>Financial Services</li>
                            <li>UX Research</li>
                            <li>Funnel Analysis</li>
                            <li>Business Rules</li>
                        </ul>
                    </div>

                    <figure class="mova-slide-frame mova-hero-slide">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-cover.jpg"
                            alt="Itaú and MOVA case study cover slide with orange textured visual language"
                            loading="eager">
                        <figcaption>Cover slide introducing the Itaú + MOVA case study.</figcaption>
                    </figure>

                    <div class="mova-meta-grid" aria-label="Project information">
                        <div>
                            <span>Date</span>
                            <strong>2024.9</strong>
                        </div>
                        <div>
                            <span>Timeline</span>
                            <strong>8 weeks</strong>
                        </div>
                        <div>
                            <span>Team</span>
                            <strong>9 members</strong>
                        </div>
                        <div>
                            <span>Context</span>
                            <strong>Professional</strong>
                        </div>
                    </div>
                </section>

                <section class="mova-story-section" id="context">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">Context</p>
                        <h2>Department store credit cards are part of a broader financial ecosystem.</h2>
                        <p>In Brazil, department store credit cards operate as strategic retail extensions, connecting
                            payment, credit, loyalty, insurance and financial services. In the Magalu + Itaú ecosystem,
                            the card is not only a payment method. It is a channel for financial products inside the
                            store experience.</p>
                    </div>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-context-cards.jpg"
                            alt="Slide explaining department store cards as part of a Brazilian financial services ecosystem"
                            loading="lazy">
                        <figcaption>Context slide framing department store cards as extensions of payment, credit and
                            retail services.</figcaption>
                    </figure>
                </section>

                <section class="mova-story-section" id="mova">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">What is MOVA?</p>
                        <h2>What is MOVA?</h2>
                        <p>MOVA is the in-store application used by operators to sell cards, manage accounts and offer
                            financial products inside Magalu stores.</p>
                    </div>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-context-platform.jpg"
                            alt="Slide introducing MOVA as an assisted sales platform used inside Magalu stores"
                            loading="lazy">
                        <figcaption>Platform context slide showing MOVA's role in assisted card and financial product
                            journeys.</figcaption>
                    </figure>
                </section>

                <section class="mova-story-section mova-challenge-section" id="challenge">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">The Challenge</p>
                        <h2>The journey needed to become simpler without losing clarity.</h2>
                        <p>The installment financing journey needed to become simpler and more efficient for operators,
                            without compromising customer understanding or commercial and financial compliance.</p>
                    </div>

                    <blockquote class="mova-hmw">
                        How might we make the installment payment flow simpler and more efficient for operators, without
                        losing clarity for customers in a debt-restructuring moment?
                    </blockquote>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-hmw-detailed.jpg"
                            alt="Detailed How Might We slide for the MOVA installment payment flow redesign"
                            loading="lazy">
                        <figcaption>Detailed How Might We slide defining the operational and customer clarity challenge.
                        </figcaption>
                    </figure>
                </section>

                <section class="mova-story-section" id="competing-needs">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">Competing Needs</p>
                        <h2>Three needs had to work together in the same flow.</h2>
                    </div>

                    <div class="mova-card-grid">
                        <div class="mova-insight-card">
                            <span>01</span>
                            <h3>Operational throughput</h3>
                            <p>Operators needed a faster flow that reduced unnecessary steps and improved store
                                productivity.</p>
                        </div>
                        <div class="mova-insight-card">
                            <span>02</span>
                            <h3>Customer comprehension</h3>
                            <p>Customers needed to understand the financial decision clearly, especially in a sensitive
                                debt-restructuring context.</p>
                        </div>
                        <div class="mova-insight-card">
                            <span>03</span>
                            <h3>Commercial and financial compliance</h3>
                            <p>The flow had to respect product rules, commercial priorities and financial governance.
                            </p>
                        </div>
                    </div>
                </section>

                <section class="mova-story-section" id="role">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">My Role</p>
                        <h2>My role connected research, data and business rules.</h2>
                        <p>I contributed through journey mapping, operator and customer research, behavioral funnel
                            analysis and business rules mapping, in collaboration with Product, BI, Design, Commercial
                            and Operations teams.</p>
                    </div>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-role.jpg"
                            alt="Slide summarizing the role and responsibilities in the MOVA project" loading="lazy">
                        <figcaption>Role slide summarizing the research, data and cross-functional contribution.
                        </figcaption>
                    </figure>
                </section>

                <section class="mova-story-section" id="research">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">Research & Diagnosis</p>
                        <h2>Understanding where the assisted journey created friction.</h2>
                        <p>Observation, shadowing, stakeholder interviews and analytics were used to understand where
                            operators faced friction and where the journey created unnecessary effort.</p>
                    </div>

                    <div class="mova-method-list" aria-label="Research methods">
                        <div>Observation and shadowing</div>
                        <div>Stakeholder interviews</div>
                        <div>Operator behavior analysis</div>
                        <div>Funnel analysis</div>
                        <div>Business rules mapping</div>
                    </div>
                </section>

                <section class="mova-story-section" id="key-challenges">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">Key Challenges</p>
                        <h2>The redesign had to account for real operational constraints.</h2>
                    </div>

                    <div class="mova-card-grid">
                        <div class="mova-insight-card">
                            <span>01</span>
                            <h3>Sensitive research context</h3>
                            <p>Debt restructuring is emotionally loaded, so research needed to be careful and indirect.
                            </p>
                        </div>
                        <div class="mova-insight-card">
                            <span>02</span>
                            <h3>Incentive-driven operator behavior</h3>
                            <p>Variable pay and productivity pressure influenced how operators used the platform.</p>
                        </div>
                        <div class="mova-insight-card">
                            <span>03</span>
                            <h3>B2B2C experience problem</h3>
                            <p>The operator had to understand the offer, explain it, handle objections and close the
                                sale while the customer made a financial decision.</p>
                        </div>
                    </div>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-challenges.jpg"
                            alt="Slide showing operational constraints and challenges in the MOVA assisted journey"
                            loading="lazy">
                        <figcaption>Challenges slide capturing the operational, behavioral and B2B2C constraints behind
                            the redesign.</figcaption>
                    </figure>
                </section>

                <section class="mova-story-section" id="solution">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">Design Strategy</p>
                        <h2>Designing a new guided journey.</h2>
                        <p>The strategy was to transform a complex financial journey into a guided flow that supports
                            the operator, protects customer clarity and reduces operational friction.</p>
                    </div>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-solution-intro.jpg"
                            alt="Slide introducing the guided journey strategy for the MOVA solution" loading="lazy">
                        <figcaption>Solution intro slide positioning the redesigned flow as a guided assisted journey.
                        </figcaption>
                    </figure>
                </section>

                <section class="mova-story-section" id="solution-walkthrough">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">Solution Walkthrough</p>
                        <h2>A redesigned journey from simulation to confirmation.</h2>
                        <p>The redesigned flow moves from the customer card area into installment options, simulation,
                            confirmation, payment and a clear success state. Each step keeps the operator oriented while
                            preserving the customer's understanding of the decision.</p>
                    </div>

                    <div class="mova-flow-list" aria-label="Redesigned flow steps">
                        <span>Customer card area</span>
                        <span>Installment option</span>
                        <span>Simulation</span>
                        <span>Confirmation</span>
                        <span>Payment</span>
                        <span>Success state</span>
                    </div>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image"
                            src="assets/images/projects/itau-mova/mova-solution-walkthrough.jpg"
                            alt="Slide showing the redesigned MOVA installment journey from simulation to success state"
                            loading="lazy">
                        <figcaption>Walkthrough slide showing the redesigned installment payment flow across key product
                            steps.</figcaption>
                    </figure>
                </section>

                <section class="mova-story-section" id="results">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">Results</p>
                        <h2>Validation and business impact.</h2>
                        <p>In the pilot and validation context, the redesigned journey showed measurable improvements in
                            speed, screen count, experience quality and completion.</p>
                    </div>

                    <div class="mova-results-grid" aria-label="Pilot results">
                        <div>
                            <strong>30%</strong>
                            <span>reduction in SLA time</span>
                        </div>
                        <div>
                            <strong>2</strong>
                            <span>fewer journey screens</span>
                        </div>
                        <div>
                            <strong>93%</strong>
                            <span>experience checklist</span>
                        </div>
                        <div>
                            <strong>8%</strong>
                            <span>increase in pilot completion rate</span>
                        </div>
                    </div>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-results.jpg"
                            alt="Slide summarizing MOVA pilot validation results and business impact metrics"
                            loading="lazy">
                        <figcaption>Results slide summarizing validation indicators from the pilot context.</figcaption>
                    </figure>
                </section>

                <section class="mova-story-section" id="reflection">
                    <div class="mova-section-heading">
                        <p class="mova-section-label">Reflection</p>
                        <h2>Interfaces in assisted channels support more than screens.</h2>
                        <p>In assisted-channel products, the interface must support three things at once: a
                            conversation, an operational goal and a financial decision.</p>
                        <p>Simplifying a financial journey in retail is not only about reducing screens. It is about
                            aligning data, operational behavior, commercial clarity and customer trust in a single
                            coherent flow.</p>
                    </div>

                    <figure class="mova-slide-frame">
                        <img class="mova-slide-image" src="assets/images/projects/itau-mova/mova-reflection.jpg"
                            alt="Reflection slide closing the MOVA case study with assisted-channel product learnings"
                            loading="lazy">
                        <figcaption>Reflection slide closing the case with the product learning behind assisted
                            financial journeys.</figcaption>
                    </figure>
                </section>
            </article>
        </div>
    </main>

    <!--@import "_footer.kit"-->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const shell = document.getElementById('movaShell');
            const toggle = document.getElementById('movaSidebarToggle');
            const sidebar = document.getElementById('movaSidebar');
            const overlay = document.getElementById('movaSidebarOverlay');

            if (!shell || !toggle || !sidebar || !overlay) return;

            const setSidebarOpen = function (isOpen) {
                shell.classList.toggle('sidebar-open', isOpen);
                toggle.setAttribute('aria-expanded', String(isOpen));
                toggle.setAttribute('aria-label', isOpen ? 'Close sidebar' : 'Open sidebar');
            };

            toggle.addEventListener('click', function (event) {
                event.stopPropagation();
                setSidebarOpen(!shell.classList.contains('sidebar-open'));
            });

            overlay.addEventListener('click', function () {
                setSidebarOpen(false);
            });

            sidebar.addEventListener('click', function (event) {
                if (event.target.closest('a')) {
                    setSidebarOpen(false);
                }
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    setSidebarOpen(false);
                }
            });
        });
    </script>
</body>

</html>