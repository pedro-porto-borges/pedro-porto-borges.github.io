<!DOCTYPE html>
<html lang="en">

<!--@import "_head.kit"-->

<body>
    <!--@import "_header.kit"-->

    <main>
        <article class="project-detail">
            <header class="project-detail-hero section-fade">
                <div class="container narrow">
                    <a href="/portfolio.html" class="back-link">Back to portfolio</a>
                    <p class="eyebrow">Project One</p>
                    <h1>Project One title goes here.</h1>
                    <p class="lead">A full description of the project goal, your role, and the final outcome. Replace this text with your real project narrative.</p>
                </div>
            </header>

            <section class="project-media-section">
                <div class="container">
                    <div class="project-cover project-cover-one project-cover-wide"></div>
                </div>
            </section>

            <section class="project-body-section">
                <div class="container detail-grid">
                    <div class="detail-content">
                        <h2>Overview</h2>
                        <p>Describe the problem, the audience, and the decisions that shaped the work. Keep the writing specific so visitors understand what you contributed.</p>
                        <h2>Process</h2>
                        <p>Explain the main steps: research, planning, wireframes, design, development, testing, and iteration.</p>
                    </div>
                    <aside class="project-facts">
                        <h2>Details</h2>
                        <dl>
                            <dt>Date</dt>
                            <dd>2026</dd>
                            <dt>Technologies</dt>
                            <dd>HTML, CSS, Prepros</dd>
                            <dt>Role</dt>
                            <dd>Design and development</dd>
                        </dl>
                    </aside>
                </div>
            </section>
        </article>
    </main>

    <!--@import "_footer.kit"-->
</body>

</html>
