<!DOCTYPE html>
<html lang="en">

<!--@import "_head.kit"-->

<body>
    <!--@import "_header.kit"-->

    <main>
        <section class="page-hero section-fade">
            <div class="container narrow">
                <p class="eyebrow">Contact</p>
                <h1>About Pedro Porto Borges.</h1>
                <p class="lead">Replace this page with your real biography, contact details, and the networks where people can follow your work.</p>
            </div>
        </section>

        <section class="contact-section">
            <div class="container contact-grid">
                <div class="about-panel">
                    <h2>Short bio</h2>
                    <p>I am a student and creator interested in web experiences, visual communication, and thoughtful front-end development. This paragraph is a placeholder for your real background, interests, and goals.</p>
                    <p>Add a little personality here: what you enjoy building, what you are learning, and what kind of collaborations you are open to.</p>
                </div>
                <aside class="social-panel">
                    <h2>External links</h2>
                    <a href="https://github.com/" target="_blank" rel="noopener">GitHub</a>
                    <a href="https://linkedin.com/" target="_blank" rel="noopener">LinkedIn</a>
                    <a href="https://instagram.com/" target="_blank" rel="noopener">Instagram</a>
                    <a href="https://behance.net/" target="_blank" rel="noopener">Behance</a>
                </aside>
            </div>
        </section>
    </main>

    <!--@import "_footer.kit"-->
</body>

</html>
