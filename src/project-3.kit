<!DOCTYPE html>
<html lang="en">

<!--@import "_head.kit"-->

<body>
    <!--@import "_header.kit"-->

    <main>
        <article class="project-detail">
            <header class="project-detail-hero section-fade">
                <div class="container narrow">
                    <a href="/portfolio.html" class="back-link">Back to portfolio</a>
                    <p class="eyebrow">Project Three</p>
                    <h1>Project Three title goes here.</h1>
                    <p class="lead">A detailed page for a visual system, website, campaign, or digital product with room for your own screenshots.</p>
                </div>
            </header>

            <section class="project-media-section">
                <div class="container">
                    <div class="project-cover project-cover-three project-cover-wide"></div>
                </div>
            </section>

            <section class="project-body-section">
                <div class="container detail-grid">
                    <div class="detail-content">
                        <h2>Overview</h2>
                        <p>Explain the initial brief, the limitations, and how you translated the idea into a finished piece.</p>
                        <h2>Process</h2>
                        <p>Describe the strongest design or development choices and what changed from first draft to final version.</p>
                    </div>
                    <aside class="project-facts">
                        <h2>Details</h2>
                        <dl>
                            <dt>Date</dt>
                            <dd>2025</dd>
                            <dt>Technologies</dt>
                            <dd>HTML, CSS, Visual Design</dd>
                            <dt>Role</dt>
                            <dd>Creative direction</dd>
                        </dl>
                    </aside>
                </div>
            </section>
        </article>
    </main>

    <!--@import "_footer.kit"-->
</body>

</html>
