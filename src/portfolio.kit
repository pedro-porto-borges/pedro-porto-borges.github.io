<!DOCTYPE html>
<html lang="en">

<!--@import "_head.kit"-->

<body>
    <!--@import "_header.kit"-->

    <main>
        <section class="page-hero section-fade">
            <div class="container narrow">
                <p class="eyebrow">Portfolio</p>
                <h1>Selected projects, experiments, and case studies.</h1>
                <p class="lead">A curated overview of four projects. Each card links to a detail page with space for your process, technologies, screenshots, and dates.</p>
            </div>
        </section>

        <section class="work-list-section">
            <div class="container">
                <div class="project-grid project-grid-large">
                    <article class="project-card">
                        <a href="/project-1.html" class="project-cover" aria-label="Open Project One">
                            <img src="/assets/images/projects/mova-hero@1x.jpg" srcset="/assets/images/projects/mova-hero@1x.jpg 1x, /assets/images/projects/mova-hero@2x.jpg 2x" width="1200" height="750" alt="Placeholder image for the MOVA assisted sales journey case study" loading="eager" decoding="async">
                        </a>
                        <div class="project-card-body">
                            <p class="project-meta">Web Design / 2026</p>
                            <h2><a href="/project-1.html">Project One</a></h2>
                            <p>Brief description for your first project. Replace this with the goal, audience, and most important result.</p>
                            <a href="/project-1.html" class="text-link">Read case study</a>
                        </div>
                    </article>
                    <article class="project-card">
                        <a href="/project-2.html" class="project-cover" aria-label="Open Project Two">
                            <img src="/assets/images/projects/eventbrite-wallet-hero@1x.jpg" srcset="/assets/images/projects/eventbrite-wallet-hero@1x.jpg 1x, /assets/images/projects/eventbrite-wallet-hero@2x.jpg 2x" width="1200" height="750" alt="Placeholder image for the Eventbrite Wallet case study" loading="lazy" decoding="async">
                        </a>
                        <div class="project-card-body">
                            <p class="project-meta">Interface / 2026</p>
                            <h2><a href="/project-2.html">Project Two</a></h2>
                            <p>Brief description for your second project. Use this space to summarize the challenge and solution.</p>
                            <a href="/project-2.html" class="text-link">Read case study</a>
                        </div>
                    </article>
                    <article class="project-card">
                        <a href="/project-3.html" class="project-cover" aria-label="Open Project Three">
                            <img src="/assets/images/projects/wise-quests-hero@1x.jpg" srcset="/assets/images/projects/wise-quests-hero@1x.jpg 1x, /assets/images/projects/wise-quests-hero@2x.jpg 2x" width="1200" height="750" alt="Placeholder image for the Wise Quests case study" loading="lazy" decoding="async">
                        </a>
                        <div class="project-card-body">
                            <p class="project-meta">Brand System / 2025</p>
                            <h2><a href="/project-3.html">Project Three</a></h2>
                            <p>Brief description for your third project. Add a sentence about the visual system or technical approach.</p>
                            <a href="/project-3.html" class="text-link">Read case study</a>
                        </div>
                    </article>
                    <article class="project-card">
                        <a href="/project-4.html" class="project-cover" aria-label="Open Project Four">
                            <img src="/assets/images/projects/project-four-hero@1x.jpg" srcset="/assets/images/projects/project-four-hero@1x.jpg 1x, /assets/images/projects/project-four-hero@2x.jpg 2x" width="1200" height="750" alt="Placeholder image for the fourth project case study" loading="lazy" decoding="async">
                        </a>
                        <div class="project-card-body">
                            <p class="project-meta">Prototype / 2025</p>
                            <h2><a href="/project-4.html">Project Four</a></h2>
                            <p>Brief description for your fourth project. Highlight the format, tools, and main learning outcome.</p>
                            <a href="/project-4.html" class="text-link">Read case study</a>
                        </div>
                    </article>
                </div>
            </div>
        </section>
    </main>

    <!--@import "_footer.kit"-->
</body>

</html>

