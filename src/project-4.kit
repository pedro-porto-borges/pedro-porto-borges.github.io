<!DOCTYPE html>
<html lang="en">

<!--@import "_head.kit"-->

<body>
    <!--@import "_header.kit"-->

    <main>
        <article class="project-detail">
            <header class="project-detail-hero section-fade">
                <div class="container narrow">
                    <a href="/portfolio.html" class="back-link">Back to portfolio</a>
                    <p class="eyebrow">Project Four</p>
                    <h1>Project Four title goes here.</h1>
                    <p class="lead">Use this page for a prototype, class exercise, or personal experiment that deserves its own context.</p>
                </div>
            </header>

            <section class="project-media-section">
                <div class="container">
                    <div class="project-cover project-cover-four project-cover-wide"></div>
                </div>
            </section>

            <section class="project-body-section">
                <div class="container detail-grid">
                    <div class="detail-content">
                        <h2>Overview</h2>
                        <p>Summarize the idea, what you built, and why it belongs in the portfolio.</p>
                        <h2>Process</h2>
                        <p>Include what you learned, how you refined the interface, and what you would improve next.</p>
                    </div>
                    <aside class="project-facts">
                        <h2>Details</h2>
                        <dl>
                            <dt>Date</dt>
                            <dd>2025</dd>
                            <dt>Technologies</dt>
                            <dd>HTML, CSS, Prototyping</dd>
                            <dt>Role</dt>
                            <dd>Concept and build</dd>
                        </dl>
                    </aside>
                </div>
            </section>
        </article>
    </main>

    <!--@import "_footer.kit"-->
</body>

</html>
