<!DOCTYPE html>
<html lang="en">

<!--@import "_head.kit"-->

<body>
    <!--@import "_header.kit"-->

    <main>
        <article class="project-detail">
            <header class="project-detail-hero section-fade">
                <div class="container narrow">
                    <a href="/portfolio.html" class="back-link">Back to portfolio</a>
                    <p class="eyebrow">Project Two</p>
                    <h1>Project Two title goes here.</h1>
                    <p class="lead">Use this page to present a more detailed case study with images, technology notes, and the date of the work.</p>
                </div>
            </header>

            <section class="project-media-section">
                <div class="container">
                    <div class="project-cover project-cover-two project-cover-wide"></div>
                </div>
            </section>

            <section class="project-body-section">
                <div class="container detail-grid">
                    <div class="detail-content">
                        <h2>Overview</h2>
                        <p>Write about the challenge and the intended user. Mention the context that makes the project meaningful.</p>
                        <h2>Process</h2>
                        <p>Add notes about sketches, layout decisions, accessibility, responsive behavior, or any testing you performed.</p>
                    </div>
                    <aside class="project-facts">
                        <h2>Details</h2>
                        <dl>
                            <dt>Date</dt>
                            <dd>2026</dd>
                            <dt>Technologies</dt>
                            <dd>HTML, CSS, Responsive Design</dd>
                            <dt>Role</dt>
                            <dd>Interface design</dd>
                        </dl>
                    </aside>
                </div>
            </section>
        </article>
    </main>

    <!--@import "_footer.kit"-->
</body>

</html>
