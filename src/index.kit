<!DOCTYPE html>
<html lang="en">

<!--@import "_head.kit"-->

<body class="react-home-page">
    <div class="react-page-shell">
        
        <!--@import "_header.kit"-->

        <main class="react-home-main">
            <section class="react-home-hero" aria-labelledby="home-title">
                <div class="react-container">
                    <div class="react-home-hero-copy">
                        <h1 id="home-title">Pedro Porto Borges</h1>
                        <p>and i'm a product designer who connects business, data, and design to create better customer
                            experiences</p>
                    </div>
                </div>
            </section>

            <section id="case-studies" class="react-home-cases" aria-labelledby="case-studies-title">
                <div class="react-container">
                    <h2 id="case-studies-title">Case Studies</h2>
                    <div class="react-home-project-grid">
                        <a class="react-home-project-card" href="/project-1.html">
                            <span class="react-home-project-visual react-gradient-itau"></span>
                            <span class="react-home-project-title">
                                <span>Project 1</span>
                                <strong>Ita&uacute; Mova</strong>
                            </span>
                        </a>

                        <a class="react-home-project-card" href="/project-2.html">
                            <span class="react-home-project-visual react-gradient-eventbrite"></span>
                            <span class="react-home-project-title">
                                <span>Project 2</span>
                                <strong>Eventbrite</strong>
                            </span>
                        </a>

                        <a class="react-home-project-card" href="/project-3.html">
                            <span class="react-home-project-visual react-gradient-wise"></span>
                            <span class="react-home-project-title">
                                <span>Project 3</span>
                                <strong>Wise</strong>
                            </span>
                        </a>

                        <a class="react-home-project-card" href="/project-4.html">
                            <span class="react-home-project-visual react-gradient-fbaul"></span>
                            <span class="react-home-project-title">
                                <span>Project 4</span>
                                <strong>Fbaul</strong>
                            </span>
                        </a>
                    </div>
                </div>
            </section>
        </main>

        <!--@import "_footer.kit"-->
    </div>
</body>

</html>